---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => !data.draft);
  return pages
    .filter((page) => page.id !== 'index') // index is handled by /index.astro
    .map((page) => ({
      params: { slug: page.id },
      props: { page },
    }));
}

interface Props {
  page: Awaited<ReturnType<typeof getCollection<'pages'>>>[number];
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <article class="prose prose-invert prose-indigo max-w-none">
    <Content />
  </article>
</BaseLayout>
