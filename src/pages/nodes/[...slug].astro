---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const nodes = await getCollection('nodes', ({ data }) => !data.draft);
  return nodes.map((node) => ({
    params: { slug: node.id },
    props: { node },
  }));
}

interface Props {
  node: Awaited<ReturnType<typeof getCollection<'nodes'>>>[number];
}

const { node } = Astro.props;
const { Content } = await render(node);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={node.data.title} description={node.data.description}>
  {/* Breadcrumb */}
  <nav class="mb-6 text-sm text-gray-500">
    <a href={`${base}/`} class="hover:text-indigo-400 transition-colors">Главная</a>
    <span class="mx-2">›</span>
    <a href={`${base}/nodes/`} class="hover:text-indigo-400 transition-colors">Каталог</a>
    <span class="mx-2">›</span>
    <span class="text-gray-300">{node.data.title}</span>
  </nav>

  {/* Meta */}
  <div class="flex flex-wrap items-center gap-3 mb-6">
    <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-indigo-500/20 text-indigo-300">
      {node.data.type}
    </span>
    {node.data.price && (
      <span class="text-lg font-bold text-cyan-400">{node.data.price}</span>
    )}
    {node.data.date && (
      <time datetime={node.data.date.toISOString()} class="text-xs text-gray-500">
        {node.data.date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    )}
  </div>

  {/* Taxonomies */}
  {node.data.taxonomies && node.data.taxonomies.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-8">
      {node.data.taxonomies.map((tax: string) => (
        <span class="px-2.5 py-0.5 rounded-md text-xs bg-gray-800 text-gray-400 border border-gray-700">
          {tax}
        </span>
      ))}
    </div>
  )}

  {/* Content */}
  <article class="prose prose-invert prose-indigo max-w-none">
    <Content />
  </article>
</BaseLayout>
