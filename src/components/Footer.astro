---
import { getCollection } from 'astro:content';

const settingsEntries = await getCollection('settings');
const bizEntry = settingsEntries.find((e) => e.id === 'business');

interface BusinessData {
  name?: string;
  phone?: string;
  email?: string;
  address?: string;
  hours?: { weekdays?: string; weekends?: string };
  social?: { telegram?: string; instagram?: string };
}

const biz = (bizEntry?.data ?? {}) as BusinessData;
---

<footer class="bg-gray-900 border-t border-gray-800 mt-auto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      {/* Brand */}
      <div>
        <h3 class="text-lg font-bold bg-gradient-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">
          {biz.name ?? 'Agentic CMS'}
        </h3>
        <p class="mt-2 text-sm text-gray-400">
          Управляется ИИ-агентом через&nbsp;естественный язык.
        </p>
      </div>

      {/* Contacts */}
      <div>
        <h4 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-3">Контакты</h4>
        <ul class="space-y-1.5 text-sm text-gray-400">
          {biz.phone && <li>📞 {biz.phone}</li>}
          {biz.email && <li>✉️ {biz.email}</li>}
          {biz.address && <li>📍 {biz.address}</li>}
        </ul>
      </div>

      {/* Hours */}
      <div>
        <h4 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-3">Часы работы</h4>
        <ul class="space-y-1.5 text-sm text-gray-400">
          {biz.hours?.weekdays && <li>Пн–Пт: {biz.hours.weekdays}</li>}
          {biz.hours?.weekends && <li>Сб–Вс: {biz.hours.weekends}</li>}
        </ul>
        {biz.social && (
          <div class="mt-4 flex gap-3">
            {biz.social.telegram && (
              <a href={biz.social.telegram} target="_blank" rel="noopener" class="text-gray-400 hover:text-indigo-400 transition-colors text-sm">
                Telegram
              </a>
            )}
            {biz.social.instagram && (
              <a href={biz.social.instagram} target="_blank" rel="noopener" class="text-gray-400 hover:text-indigo-400 transition-colors text-sm">
                Instagram
              </a>
            )}
          </div>
        )}
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-800 text-center text-xs text-gray-500">
      © {new Date().getFullYear()} {biz.name ?? 'Agentic CMS'}. Работает на Astro.js
    </div>
  </div>
</footer>
